FROM node:lts-alpine

# Install cURL for health checks
RUN apk add --no-cache curl

# Set working directory
WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy application files (node_modules are ignored)
COPY . .

# Environment
ENV NODE_ENV=production
ENV PORT=3000
EXPOSE 3000

# Run the application
CMD ["npm", "start"]
