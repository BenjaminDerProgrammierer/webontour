{
  "name": "webontour-updater",
  "version": "1.0.0",
  "author": "Benjamin Hartmann <benjamin.p.hartmann@gmail.com>",
  "license": "GPL-3.0-only",
  "private": true,
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && npm run start:prod",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"tsx src/index.ts\""
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.19",
    "nodemon": "^3.1.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
